# Public repo defaults — optional overrides
VITE_GITHUB_OWNER=LucaIsMyName
VITE_GITHUB_REPO=-skills-
VITE_GITHUB_REF=main

# Optional: raises GitHub API rate limits for the tree request. WARNING: any
# VITE_* value is embedded in the browser bundle — treat it as public, not a secret.
# For a private token, use a backend proxy instead.
# VITE_GITHUB_TOKEN=
